* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
    font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
}

body {
    background-color: #0b0f19;
    color: #ffffff;
    overflow-x: hidden;
}

.container {
    width: 90%;
    max-width: 1200px;
    margin: 0 auto;
}

.hero-section {
    position: relative;
    height: 60vh;
    min-height: 400px;
   background: url('https://thumbs.dreamstime.com/b/amazing-view-caucasus-mountains-kazbegi-village-georgia-one-absolute-must-visit-places-has-to-be-key-part-any-241782714.jpg') no-repeat center center/cover;
    display: flex;
    align-items: center;
    text-align: center;
}

.hero-section .overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(to bottom, rgba(11, 15, 25, 0.4), #0b0f19);
    z-index: 1;
}

.hero-container {
    position: relative;
    z-index: 2;
}

.tricolor-line {
    display: flex;
    justify-content: center;
    gap: 8px;
    margin-bottom: 20px;
}

.tricolor-line span {
    width: 40px;
    height: 4px;
    border-radius: 2px;
}

.tricolor-line .blue { background-color: #00b4d8; }
.tricolor-line .red { background-color: #ef476f; }
.tricolor-line .green { background-color: #06d6a0; }

.hero-section h1 {
    font-size: 3rem;
    font-weight: 700;
    margin-bottom: 20px;
    letter-spacing: 1px;
}

.hero-section p {
    font-size: 1.1rem;
    max-width: 800px;
    margin: 0 auto;
    line-height: 1.8;
    color: #cbd5e1;
}

.search-section {
    padding: 40px 0;
    text-align: center;
}

.search-box {
    display: flex;
    align-items: center;
    max-width: 900px;
    margin: 0 auto 15px auto;
    background-color: #162235;
    border: 1px solid #1e293b;
    border-radius: 12px;
    overflow: hidden;
}

.search-box input {
    flex: 1;
    padding: 18px 25px;
    background: transparent;
    border: none;
    color: #fff;
    font-size: 1rem;
    outline: none;
}

.search-box input:focus {
    border-color: #00b4d8;
    box-shadow: 0 0 10px rgba(0, 180, 216, 0.2);
}

.search-box button {
    width: 55px;
    height: 55px;
    background-color: #00b4d8;
    border: none;
    color: white;
    cursor: pointer;
    font-size: 1.1rem;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background-color 0.2s;
}

.search-box button:hover {
    background-color: #0096b6;
}

.search-hint {
    color: #94a3b8;
    font-size: 0.9rem;
}

.hero-of-day-section {
    padding: 60px 0;
    text-align: center;
}

.section-title {
    font-size: 1.8rem;
    font-weight: 600;
    margin-bottom: 10px;
}

.star { color: #fcc419; }

.current-date {
    color: #94a3b8;
    font-size: 0.95rem;
    margin-bottom: 30px;
}

.hero-card {
    display: flex;
    background-color: #111827;
    border: 1px solid #1f2937;
    border-radius: 16px;
    overflow: hidden;
    max-width: 900px;
    margin: 0 auto;
    text-align: left;
    box-shadow: 0 10px 25px rgba(0,0,0,0.3);
}

.hero-image-side {
    position: relative;
    width: 45%;
    min-height: 350px;
}

.hero-image-side img {
    width: 100%;
    height: 100%;
    object-fit: cover;
}

.card-indicator {
    position: absolute;
    top: 20px;
    left: 20px;
    display: flex;
    gap: 5px;
}

.card-indicator span {
    width: 8px;
    height: 20px;
    border-radius: 4px;
